---
// Marca de agua "G2B" — refuerzo de marca en espacios vacíos. Muy sutil.
interface Props {
  tone?: "dark" | "light";
  class?: string; // posición + tamaño, ej: "text-[26rem] -right-12 -bottom-32"
}
const { tone = "dark", class: cls = "" } = Astro.props;
const color = tone === "dark" ? "text-white/[0.035]" : "text-navy-900/[0.04]";
---
<span
  class={`pointer-events-none absolute select-none font-display font-extrabold leading-none tracking-tighter ${color} ${cls}`}
  aria-hidden="true"
>G2B</span>
