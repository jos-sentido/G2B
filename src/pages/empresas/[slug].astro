---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import FlowLines from "../../components/FlowLines.astro";
import { companies, brand } from "../../data/site";
import { empresaDetail } from "../../data/empresas";

export function getStaticPaths() {
  return companies.map((c) => ({
    params: { slug: c.slug },
    props: { company: c },
  }));
}

const { company } = Astro.props;
const detail = empresaDetail[company.slug];
const others = companies.filter((c) => c.slug !== company.slug);
const idx = companies.findIndex((c) => c.slug === company.slug);
const num = String(idx + 1).padStart(2, "0");
---

<Base
  title={`${company.name} — ${detail.tagline} | ${brand.name}`}
  description={detail.intro[0]}
  image={company.img || "/img/logo-g2b.png"}
>
  <Header />
  <main id="inicio">

    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden bg-navy-950 text-white" style={`border-bottom:3px solid ${company.color}`}>
      <FlowLines tone="dark" />
      <!-- tinte de marca -->
      <div class="pointer-events-none absolute inset-0" style={`background:radial-gradient(120% 90% at 100% 0%, ${company.color}33 0%, transparent 55%)`}></div>

      <div class="container-g2b relative z-10 py-16 lg:py-24">
        <a href="/#empresas" class="inline-flex items-center gap-2 text-sm font-medium text-steel-100/70 hover:text-white transition-colors">
          <Icon name="arrow" class="w-4 h-4 rotate-180" /> Empresas del grupo
        </a>

        <div class="mt-8 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div>
            <div class="flex items-center gap-3">
              <span class="font-display text-sm font-bold tracking-widest" style={`color:${company.color}`}>{num}</span>
              <span class="h-px w-10" style={`background:${company.color}`}></span>
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-steel-100/60">Empresa del grupo</span>
            </div>
            <h1 class="mt-4 font-display text-5xl font-extrabold leading-none lg:text-7xl">{company.name}</h1>
            <p class="mt-4 text-xl font-semibold" style={`color:${company.color === '#163C7A' ? '#5b8de0' : company.color}`}>{detail.tagline}</p>
            <div class="mt-6 space-y-4 text-steel-100/80 leading-relaxed lg:max-w-xl">
              {detail.intro.map((p) => <p>{p}</p>)}
            </div>
            <div class="mt-8 flex flex-wrap gap-3">
              <a href="/#contacto" class="inline-flex items-center gap-2 rounded-lg px-6 py-3 font-semibold text-white transition-opacity hover:opacity-90" style={`background:${company.color}`}>
                Contáctanos <Icon name="arrow" class="w-4 h-4" />
              </a>
              {company.website
                ? (
                  <a href={company.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-white/25 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                    Visitar sitio de {company.name} <Icon name="external" class="w-4 h-4" />
                  </a>
                )
                : (
                  <span class="inline-flex cursor-not-allowed items-center gap-2 rounded-lg border border-white/15 px-6 py-3 font-semibold text-steel-100/45" aria-disabled="true" title="Sitio oficial en preparación">
                    Sitio oficial — próximamente <Icon name="external" class="w-4 h-4" />
                  </span>
                )
              }
              <a href="#areas" class="inline-flex items-center gap-2 rounded-lg border border-white/25 px-6 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
                Ver especialidades
              </a>
            </div>
          </div>

          <!-- Imagen -->
          <div class="relative">
            <div class="overflow-hidden rounded-brand shadow-2xl" style={`border-top:3px solid ${company.color}`}>
              {company.img
                ? <img src={company.img} alt={`${company.name} — obra`} class="h-72 w-full object-cover lg:h-96" />
                : <div class="flex h-72 w-full items-center justify-center bg-navy-800 lg:h-96"><span class="font-display text-3xl font-bold" style={`color:${company.color}`}>{company.name}</span></div>
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ ÁREAS DE ESPECIALIDAD ============ -->
    <section id="areas" class="py-20 lg:py-28">
      <div class="container-g2b">
        <div class="mb-4 h-[3px] w-10 rounded-full" style={`background:${company.color}`}></div>
        <div class="grid gap-6 lg:grid-cols-[1fr_1.4fr] lg:items-end">
          <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">Áreas de especialidad</h2>
          <p class="text-steel-700">Lo que {company.name} ejecuta dentro del modelo integral del grupo — capacidades específicas, no servicios genéricos.</p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {detail.areas.map((a) => (
            <article class="group relative overflow-hidden rounded-brand border border-steel-100 bg-white p-7 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style={`background:${company.color}14; color:${company.color}`}>
                  <Icon name={a.icon} class="w-6 h-6" />
                </div>
                <div>
                  <h3 class="font-display text-lg font-bold text-navy-900">{a.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-steel-700">{a.desc}</p>
                </div>
              </div>
              <ul class="mt-5 grid grid-cols-1 gap-2 sm:grid-cols-2">
                {a.items.map((it) => (
                  <li class="flex items-center gap-2 text-sm text-steel-700">
                    <Icon name="check" class="w-4 h-4 shrink-0 text-eco-500" />{it}
                  </li>
                ))}
              </ul>
              <div class="mt-5 h-[2px] w-0 rounded-full transition-all duration-500 group-hover:w-full" style={`background:${company.color}`}></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ APLICACIONES + RESPALDO ============ -->
    <section class="bg-paper py-20 lg:py-24">
      <div class="container-g2b grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="font-display text-2xl font-bold text-navy-900">¿Dónde se aplica?</h2>
          <p class="mt-2 text-steel-700">Sectores y proyectos donde {company.name} aporta su especialidad.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            {detail.aplicaciones.map((ap) => (
              <span class="inline-flex items-center gap-2 rounded-full border border-steel-200 bg-white px-4 py-2.5 text-sm font-semibold text-navy-900 shadow-sm">
                <span class="h-2 w-2 rounded-full" style={`background:${company.color}`}></span>{ap}
              </span>
            ))}
          </div>
        </div>

        {detail.respaldo && (
          <div>
            <h2 class="font-display text-2xl font-bold text-navy-900">Respaldo</h2>
            <p class="mt-2 text-steel-700">Capacidades y datos documentados del grupo.</p>
            <ul class="mt-6 space-y-3">
              {detail.respaldo.map((r) => (
                <li class="flex items-center gap-3 rounded-xl border border-steel-100 bg-white px-5 py-4 shadow-sm">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg" style={`background:${company.color}14; color:${company.color}`}>
                    <Icon name="check" class="w-5 h-5" />
                  </span>
                  <span class="text-sm font-semibold text-navy-900">{r}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>

    <!-- ============ ROL EN EL GRUPO ============ -->
    <section class="py-20 lg:py-24">
      <div class="container-g2b">
        <div class="relative overflow-hidden rounded-brand bg-navy-900 p-9 text-white lg:p-12" style={`border-left:4px solid ${company.color}`}>
          <p class="text-xs font-semibold uppercase tracking-[0.18em]" style={`color:${company.color === '#163C7A' ? '#5b8de0' : company.color}`}>Su rol en el grupo</p>
          <p class="mt-4 font-display text-2xl font-bold leading-snug lg:text-3xl lg:max-w-3xl">{detail.rolEnGrupo}</p>
          <p class="mt-4 text-steel-100/70 lg:max-w-2xl">{brand.taglines.team}</p>
          <a href="/#modelo" class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-white hover:opacity-80 transition-opacity">
            Conocer el modelo integral G2B <Icon name="arrow" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- ============ OTRAS EMPRESAS ============ -->
    <section class="bg-paper py-20 lg:py-24">
      <div class="container-g2b">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
          <h2 class="font-display text-2xl font-bold text-navy-900">Otras empresas del grupo</h2>
          <a href="/#empresas" class="inline-flex items-center gap-2 text-sm font-semibold text-water-600 hover:text-water-700 transition-colors">
            Ver las cinco <Icon name="arrow" class="w-4 h-4" />
          </a>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {others.map((c) => (
            <a href={`/empresas/${c.slug}`} class="group rounded-brand border border-steel-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg" style={`border-top:3px solid ${c.color}`}>
              <div class="flex h-11 w-11 items-center justify-center rounded-xl" style={`background:${c.color}14; color:${c.color}`}>
                <Icon name={c.icon} class="w-5 h-5" />
              </div>
              <p class="mt-4 font-display text-lg font-bold text-navy-900">{c.name}</p>
              <p class="mt-1 text-sm leading-relaxed text-steel-600">{c.specialty}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold" style={`color:${c.color}`}>
                Ver especialidad <Icon name="arrow" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>
