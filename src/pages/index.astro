---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { brand, stats, solutions, modelo, capacity, experience, audiences } from "../data/site";

const totalCapacity = Object.values(capacity).flat().reduce((a, b) => a + b.qty, 0);
const fmtM = (n: number) => "$" + (n / 1_000_000).toLocaleString("es-MX", { maximumFractionDigits: 1 }) + "M";
const maxType = Math.max(...experience.byType.map((t) => t.amount));
const totalSector = experience.bySector.reduce((a, b) => a + b.amount, 0);

// Lectura técnica del hero (datos protagonistas)
const readout = [
  { value: 943, prefix: "$", suffix: "M", label: "MXN ejecutados en obra", sub: "$943,188,292.78" },
  { value: 170000, prefix: "+", suffix: "", label: "Plántulas entregadas", sub: "Especies nativas y endémicas" },
  { value: totalCapacity, prefix: "+", suffix: "", label: "Equipos y plantas propias", sub: "Maquinaria pesada y especializada" },
];
---

<Base>
  <Header />

  <main id="inicio">
    <!-- ============ 01 · HERO EDITORIAL ASIMÉTRICO ============ -->
    <section class="relative bg-wave text-white overflow-hidden">
      <div class="absolute inset-0 blueprint-dark opacity-70"></div>
      <div class="container-g2b relative z-10 grid items-center gap-12 pt-16 pb-28 lg:grid-cols-12 lg:gap-8 lg:pt-24 lg:pb-36">
        <!-- Columna texto -->
        <div class="lg:col-span-7">
          <p class="flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-water-200">
            <span class="sec-index text-water-400">01</span>
            <span class="h-px w-8 bg-water-400/60"></span>
            Infraestructura estratégica · Cobertura nacional
          </p>
          <h1 class="mt-7 font-display text-[2.6rem] font-extrabold leading-[1.02] sm:text-6xl lg:text-7xl">
            Infraestructura<br />que conecta,
            <span class="text-water-400">agua</span><br />que <span class="text-water-400">transforma</span>.
          </h1>
          <p class="mt-7 max-w-xl text-lg text-steel-100/90 leading-relaxed">
            Diseñamos, construimos, rehabilitamos y operamos infraestructura hidráulica,
            sanitaria y urbana de alto impacto — integrando ingeniería, sustentabilidad y
            restauración ambiental.
          </p>
          <div class="mt-9 flex flex-col sm:flex-row gap-4">
            <a href="#contacto" class="inline-flex items-center justify-center gap-2 rounded-lg bg-water-500 px-7 py-3.5 font-semibold text-white hover:bg-water-400 transition-colors">
              Solicitar propuesta <Icon name="arrow" class="w-4 h-4" />
            </a>
            <a href="#soluciones" class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/25 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition-colors">
              Ver soluciones
            </a>
          </div>
        </div>

        <!-- Columna lectura técnica (ficha de datos como protagonista) -->
        <div class="lg:col-span-5">
          <div class="rounded-brand border border-white/15 bg-white/[0.04] backdrop-blur-sm">
            <div class="flex items-center justify-between border-b border-white/10 px-6 py-3">
              <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-steel-100/70">Ficha de capacidad</span>
              <span class="sec-index text-xs text-water-400">G2B · 2026</span>
            </div>
            <dl class="divide-y divide-white/10">
              {readout.map((r) => (
                <div class="flex items-end justify-between gap-4 px-6 py-5">
                  <dt class="max-w-[9rem] text-sm text-steel-100/85">
                    {r.label}
                    <span class="mt-0.5 block text-[11px] text-steel-100/50">{r.sub}</span>
                  </dt>
                  <dd class="stat-mega text-4xl text-white sm:text-5xl">
                    <span class="counter" data-target={r.value} data-prefix={r.prefix} data-suffix={r.suffix}>{r.prefix}0{r.suffix}</span>
                  </dd>
                </div>
              ))}
            </dl>
          </div>
          <!-- Slot de video/foto real (duotono) -->
          <div class="media-slot duotone mt-4 h-28 rounded-brand border-white/15 text-white/70">
            Video / imágenes reales de obra — pendiente del cliente
          </div>
        </div>
      </div>

      <!-- Línea de agua animada (divisor) -->
      <svg class="relative z-10 block w-full" viewBox="0 0 1440 70" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path class="water-draw" style="--len:1" pathLength="1" d="M0 40 C 180 10, 320 70, 520 40 S 900 10, 1080 40 1440 35 1440 35" stroke="var(--color-water-400)" stroke-width="2" opacity="0.55" />
        <path d="M0 50 C 180 22, 320 78, 520 50 S 900 22, 1080 50 1440 46 L1440 70 L0 70 Z" fill="rgba(56,182,224,0.08)" />
      </svg>
    </section>

    <!-- ============ 02 · DIFERENCIADOR: INFRA + MEDIO AMBIENTE ============ -->
    <section id="diferenciador" class="blueprint py-20 lg:py-28">
      <div class="container-g2b">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
          <div class="lg:col-span-5">
            <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-600">
              <span class="sec-index">02</span><span class="h-px w-8 bg-water-600/40"></span>Diferenciador
            </p>
            <h2 class="r-in mt-4 font-display text-3xl font-bold text-navy-900 lg:text-[2.6rem] lg:leading-[1.05]">
              No solo construimos obra.<br /><span class="text-water-600">Regeneramos</span> el territorio.
            </h2>
            <p class="r-in mt-5 text-lg text-steel-700 leading-relaxed" style="--d:80ms">
              A diferencia de una constructora tradicional, G2B combina capacidad de ejecución
              con un compromiso real con el agua: cada proyecto integra infraestructura,
              sustentabilidad, restauración ambiental y desarrollo territorial.
            </p>
            <ul class="r-in mt-7 grid grid-cols-2 gap-x-6 gap-y-3" style="--d:140ms">
              {["Infraestructura","Sustentabilidad","Restauración ambiental","Desarrollo territorial","Gestión hídrica","Soluciones integrales"].map((d) => (
                <li class="flex items-center gap-2.5 text-navy-900 font-medium">
                  <Icon name="check" class="w-5 h-5 text-eco-500 shrink-0" />{d}
                </li>
              ))}
            </ul>
          </div>

          <div class="lg:col-span-7">
            <!-- Métrica ambiental protagonista -->
            <div class="r-in metric-pulse rounded-brand bg-navy-800 p-8 text-white lg:p-10" style="--d:120ms">
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="stat-mega text-6xl text-water-400 lg:text-7xl">
                    <span class="counter" data-target="170000" data-prefix="" data-suffix="">+0</span>
                  </p>
                  <p class="mt-2 text-lg font-semibold">plántulas entregadas</p>
                  <p class="text-sm text-steel-100/70">de especies nativas y endémicas</p>
                </div>
                <Icon name="leaf" class="w-10 h-10 text-eco-500 shrink-0" />
              </div>
            </div>
            <div class="mt-5 grid gap-5 sm:grid-cols-3">
              {[
                { icon: "shield", t: "Cumplimiento normativo", d: "NOM-001, NOM-002, NOM-003 y estándares ESG." },
                { icon: "recycle", t: "Cuencas protegidas", d: "Mejor infiltración y recuperación hidráulica." },
                { icon: "gov", t: "Coordinación institucional", d: "Gobierno, comunidades y sector privado." },
              ].map((c, i) => (
                <div class="r-in border-t-2 border-water-500 bg-white p-6" style={`--d:${160 + i * 80}ms`}>
                  <Icon name={c.icon} class="w-7 h-7 text-water-600" />
                  <p class="mt-4 font-display text-base font-bold text-navy-900">{c.t}</p>
                  <p class="mt-1 text-sm text-steel-700 leading-relaxed">{c.d}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 03 · SOLUCIONES ============ -->
    <section id="soluciones" class="bg-paper py-20 lg:py-28">
      <div class="container-g2b">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-600">
              <span class="sec-index">03</span><span class="h-px w-8 bg-water-600/40"></span>Soluciones
            </p>
            <h2 class="mt-4 font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem]">Cinco líneas, una infraestructura integral del agua</h2>
          </div>
          <p class="max-w-sm text-steel-700">Capacidad para participar en diseño, construcción, rehabilitación y operación de cada proyecto.</p>
        </div>

        <div class="mt-12 grid gap-px overflow-hidden rounded-brand bg-steel-100 md:grid-cols-2 lg:grid-cols-3">
          {solutions.map((s, i) => (
            <article class={`group relative flex flex-col p-7 transition-colors lg:p-8 ${s.featured ? "bg-navy-800 text-white" : "bg-white hover:bg-paper"}`}>
              <div class="flex items-center justify-between">
                <span class={`sec-index text-sm ${s.featured ? "text-water-400" : "text-steel-300"}`}>{String(i + 1).padStart(2, "0")}</span>
                {s.featured && <span class="rounded-full bg-water-500 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white">Servicio estrella</span>}
              </div>
              <div class={`mt-5 flex h-11 w-11 items-center justify-center rounded-lg ${s.featured ? "bg-white/10 text-water-400" : "bg-navy-800/5 text-navy-800"}`}>
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class={`mt-4 font-display text-xl font-bold ${s.featured ? "text-white" : "text-navy-900"}`}>{s.title}</h3>
              <p class={`mt-2 text-sm leading-relaxed ${s.featured ? "text-steel-100/85" : "text-steel-700"}`}>{s.short}</p>
              <ul class="mt-5 space-y-2">
                {s.services.slice(0, 4).map((srv) => (
                  <li class={`flex items-center gap-2 text-sm ${s.featured ? "text-steel-100/85" : "text-steel-700"}`}>
                    <Icon name="check" class={`w-4 h-4 shrink-0 ${s.featured ? "text-water-400" : "text-eco-500"}`} />{srv}
                  </li>
                ))}
              </ul>
              <a href="#contacto" class={`mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold ${s.featured ? "text-water-400" : "text-water-600"}`}>
                Más información <Icon name="arrow" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
              </a>
              <span class={`absolute inset-x-0 bottom-0 h-0.5 origin-left scale-x-0 bg-water-500 transition-transform duration-300 group-hover:scale-x-100 ${s.featured ? "hidden" : ""}`}></span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 04 · EL MODELO G2B (pieza estrella) ============ -->
    <section id="modelo" class="relative bg-wave py-20 text-white lg:py-28 overflow-hidden">
      <div class="absolute inset-0 blueprint-dark opacity-60"></div>
      <div class="container-g2b relative z-10">
        <div class="max-w-2xl">
          <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-400">
            <span class="sec-index">04</span><span class="h-px w-8 bg-water-400/50"></span>El Modelo G2B
          </p>
          <h2 class="mt-4 font-display text-3xl font-bold lg:text-[2.4rem]">De una gota de agua a una comunidad que crece</h2>
          <p class="mt-4 text-lg text-steel-100/90">Un modelo propio de restauración hídrica y desarrollo territorial: cómo un proyecto hidráulico genera impacto económico, social y ambiental.</p>
        </div>

        <!-- Camino de agua que se traza -->
        <div class="relative mt-16">
          <svg class="absolute left-0 top-7 hidden w-full lg:block" height="60" viewBox="0 0 1200 60" fill="none" preserveAspectRatio="none" aria-hidden="true">
            <path class="water-draw" style="--len:1" pathLength="1" d="M40 30 C 180 0, 280 60, 420 30 S 700 0, 840 30 1160 30 1160 30" stroke="var(--color-water-400)" stroke-width="2.5" />
          </svg>

          <ol class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5 lg:gap-4">
            {modelo.map((m, i) => (
              <li class="r-in relative" style={`--d:${i * 140 + 200}ms`}>
                <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full border-2 border-water-400 bg-navy-900 stat-mega text-xl text-water-400">{m.n}</div>
                <h3 class="mt-5 font-display text-lg font-bold">{m.title}</h3>
                <p class="mt-2 text-sm text-steel-100/80 leading-relaxed">{m.desc}</p>
              </li>
            ))}
          </ol>
        </div>

        <p class="mt-14 font-display text-xl font-semibold text-water-200">{brand.taglines.primary}</p>
      </div>
    </section>

    <!-- ============ 05 · CAPACIDAD OPERATIVA ============ -->
    <section id="capacidad" class="py-20 lg:py-28">
      <div class="container-g2b">
        <div class="grid gap-10 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-600">
              <span class="sec-index">05</span><span class="h-px w-8 bg-water-600/40"></span>Capacidad operativa
            </p>
            <h2 class="mt-4 font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">Flota propia, lista para cualquier reto</h2>
            <p class="mt-4 text-steel-700">Maquinaria, plantas y transporte propios para ejecutar múltiples proyectos de gran escala con eficiencia, seguridad y calidad.</p>
            <div class="mt-8 inline-flex items-baseline gap-3 border-t-2 border-water-500 pt-4">
              <span class="stat-mega text-6xl text-navy-800 lg:text-7xl">{totalCapacity}+</span>
              <span class="text-sm text-steel-700">equipos<br/>y plantas propias</span>
            </div>
          </div>

          <div class="grid gap-8 sm:grid-cols-3 lg:col-span-8">
            {Object.entries(capacity).map(([group, items]) => (
              <div class="r-in">
                <h3 class="border-b border-steel-300 pb-3 text-xs font-bold uppercase tracking-wider text-navy-900">{group}</h3>
                <ul class="mt-2 divide-y divide-steel-100">
                  {items.map((it) => (
                    <li class="flex items-center justify-between gap-3 py-2.5">
                      <span class="text-sm text-steel-700">{it.item}</span>
                      <span class="stat-mega text-lg text-water-600">{it.qty}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 06 · EXPERIENCIA COMERCIAL ============ -->
    <section id="experiencia" class="blueprint py-20 lg:py-28">
      <div class="container-g2b">
        <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-600">
          <span class="sec-index">06</span><span class="h-px w-8 bg-water-600/40"></span>Experiencia comprobada
        </p>
        <div class="mt-6 grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
          <div>
            <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">Casi mil millones de pesos en obra ejecutada</h2>
            <div class="mt-8 border-t-2 border-navy-800 pt-5">
              <p class="text-sm uppercase tracking-wider text-steel-700">Monto total ejecutado (MXN)</p>
              <p class="stat-mega mt-1 text-6xl text-navy-800 lg:text-7xl">
                <span class="counter" data-target="943" data-prefix="$" data-suffix="M">$0M</span>
              </p>
            </div>
            <div class="mt-7 space-y-4">
              {experience.bySector.map((sec) => (
                <div>
                  <div class="flex justify-between text-sm font-medium text-navy-900">
                    <span>{sec.label}</span><span class="stat-mega">{fmtM(sec.amount)}</span>
                  </div>
                  <div class="mt-1.5 h-2.5 rounded-full bg-steel-100">
                    <div class="h-2.5 rounded-full bg-water-500" style={`width:${(sec.amount / totalSector * 100).toFixed(1)}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-brand border border-steel-100 bg-white p-7 lg:p-8">
            <h3 class="font-display text-lg font-bold text-navy-900">Distribución por tipo de obra</h3>
            <ul class="mt-6 space-y-5">
              {experience.byType.map((t) => (
                <li>
                  <div class="flex items-baseline justify-between gap-3">
                    <span class="text-sm font-medium text-navy-900">{t.label}</span>
                    <span class="stat-mega text-sm text-water-600">{fmtM(t.amount)}</span>
                  </div>
                  <div class="mt-1.5 h-2.5 rounded-full bg-steel-100">
                    <div class="h-2.5 rounded-full bg-navy-700" style={`width:${(t.amount / maxType * 100).toFixed(1)}%`}></div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Casos de éxito (duotono, pendiente del cliente) -->
        <div class="mt-14">
          <h3 class="font-display text-xl font-bold text-navy-900">Proyectos destacados</h3>
          <div class="mt-5 grid gap-6 md:grid-cols-3">
            {[1,2,3].map(() => (
              <div class="media-slot duotone h-52 rounded-brand text-white/75">Caso de éxito — pendiente del cliente<br/>(cliente · ubicación · monto · foto)</div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 07 · AUDIENCIAS / NOSOTROS ============ -->
    <section id="nosotros" class="py-20 lg:py-28">
      <div class="container-g2b">
        <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-600">
          <span class="sec-index">07</span><span class="h-px w-8 bg-water-600/40"></span>Para quién trabajamos
        </p>
        <h2 class="mt-4 max-w-2xl font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem]">Aliados del sector público y privado</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <div class="border-t-2 border-navy-800 bg-white p-8">
            <div class="flex items-center gap-3">
              <Icon name="gov" class="w-7 h-7 text-navy-800" />
              <h3 class="font-display text-xl font-bold text-navy-900">Gobierno</h3>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              {audiences.gobierno.map((a) => <span class="rounded-full bg-paper px-3.5 py-1.5 text-sm font-medium text-navy-900 border border-steel-100">{a}</span>)}
            </div>
          </div>
          <div class="border-t-2 border-water-500 bg-white p-8">
            <div class="flex items-center gap-3">
              <Icon name="building" class="w-7 h-7 text-water-600" />
              <h3 class="font-display text-xl font-bold text-navy-900">Sector privado</h3>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              {audiences.privado.map((a) => <span class="rounded-full bg-paper px-3.5 py-1.5 text-sm font-medium text-navy-900 border border-steel-100">{a}</span>)}
            </div>
          </div>
        </div>
        <div class="mt-10 rounded-brand border border-dashed border-steel-300 bg-paper p-7 text-sm text-steel-600">
          <strong class="text-navy-900">Pendiente del cliente:</strong> año de fundación, misión, visión, valores redactados, certificaciones, licencias y registros de contratista.
        </div>
      </div>
    </section>

    <!-- ============ 08 · CTA / CONTACTO ============ -->
    <section id="contacto" class="relative bg-wave py-20 text-white lg:py-28 overflow-hidden">
      <div class="absolute inset-0 blueprint-dark opacity-60"></div>
      <div class="container-g2b relative z-10 grid gap-12 lg:grid-cols-2">
        <div>
          <p class="flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-water-400">
            <span class="sec-index">08</span><span class="h-px w-8 bg-water-400/50"></span>Contacto
          </p>
          <h2 class="mt-4 font-display text-3xl font-bold lg:text-[2.4rem]">Construyamos juntos el siguiente proyecto</h2>
          <p class="mt-4 max-w-md text-lg text-steel-100/90">{brand.taglines.team} Cuéntanos sobre tu proyecto y te preparamos una propuesta a la medida.</p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-center gap-3"><Icon name="phone" class="w-5 h-5 text-water-400" /><span>{brand.contact.phone || "Teléfono — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="mail" class="w-5 h-5 text-water-400" /><span>{brand.contact.email || "Correo — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="whatsapp" class="w-5 h-5 text-water-400" /><span>{brand.contact.whatsapp || "WhatsApp — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="pin" class="w-5 h-5 text-water-400" /><span>{brand.contact.address || "Dirección — pendiente del cliente"}</span></li>
          </ul>
        </div>

        <form class="rounded-brand bg-white p-7 text-navy-900 shadow-2xl lg:p-8" onsubmit="event.preventDefault(); this.querySelector('#form-msg').classList.remove('hidden');">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium">Nombre</span>
              <input type="text" required autocomplete="name" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Empresa / Dependencia</span>
              <input type="text" autocomplete="organization" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Correo</span>
              <input type="email" required autocomplete="email" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Teléfono</span>
              <input type="tel" autocomplete="tel" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
          </div>
          <label class="mt-4 block">
            <span class="text-sm font-medium">Tipo de solución de interés</span>
            <select class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200">
              {solutions.map((s) => <option>{s.title}</option>)}
            </select>
          </label>
          <label class="mt-4 block">
            <span class="text-sm font-medium">Mensaje</span>
            <textarea rows="3" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200"></textarea>
          </label>
          <button type="submit" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-water-600 px-6 py-3.5 font-semibold text-white hover:bg-water-500 transition-colors">
            Enviar solicitud <Icon name="arrow" class="w-4 h-4" />
          </button>
          <p id="form-msg" role="status" aria-live="polite" class="hidden mt-3 text-center text-sm text-eco-600 font-medium">¡Gracias! (Demo — falta conectar el envío del formulario.)</p>
        </form>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Contadores + reveal al hacer scroll -->
  <script>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fmt = (n: number) => n.toLocaleString("es-MX");

    // Contadores animados
    const animate = (el: HTMLElement) => {
      const target = Number(el.dataset.target || "0");
      const prefix = el.dataset.prefix || "";
      const suffix = el.dataset.suffix || "";
      if (reduceMotion) { el.textContent = prefix + fmt(target) + suffix; return; }
      const dur = 1500;
      const start = performance.now();
      const step = (t: number) => {
        const p = Math.min((t - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + fmt(Math.floor(eased * target)) + suffix;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = prefix + fmt(target) + suffix;
      };
      requestAnimationFrame(step);
    };
    const counters = document.querySelectorAll<HTMLElement>(".counter");
    const ioCount = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { animate(e.target as HTMLElement); ioCount.unobserve(e.target); } });
    }, { threshold: 0.4 });
    counters.forEach((c) => ioCount.observe(c));

    // Reveal + trazo de agua
    const reveals = document.querySelectorAll(".r-in, .water-draw");
    const ioReveal = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-in"); ioReveal.unobserve(e.target); } });
    }, { threshold: 0.2 });
    reveals.forEach((r) => ioReveal.observe(r));
  </script>
</Base>
