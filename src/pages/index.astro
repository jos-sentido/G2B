---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import FlowLines from "../components/FlowLines.astro";
import Monogram from "../components/Monogram.astro";
import { brand, companies, integralModel, specialties, differentiators, audiencesGroup, capacity, experience } from "../data/site";

const totalCapacity = Object.values(capacity).flat().reduce((a, b) => a + b.qty, 0);
const fmtM = (n: number) => "$" + (n / 1_000_000).toLocaleString("es-MX", { maximumFractionDigits: 1 }) + "M";
const maxType = Math.max(...experience.byType.map((t) => t.amount));

const readout = [
  { value: 943, prefix: "$", suffix: "M", label: "MXN ejecutados en obra", sub: "Trayectoria del grupo" },
  { value: 5, prefix: "", suffix: "", label: "Empresas especializadas", sub: "Un solo grupo, toda la capacidad" },
  { value: totalCapacity, prefix: "+", suffix: "", label: "Equipos y plantas propias", sub: "Maquinaria pesada y especializada" },
];
---

<Base
  title={`${brand.name} | Infraestructura que transforma México`}
  description="Grupo Constructor G2B: plataforma empresarial mexicana integrada por 5 compañías especializadas en pavimentación, edificación, infraestructura hidráulica, desarrollo inmobiliario y estructuras de acero. Proyectos llave en mano de alto impacto nacional."
>
  <Header />

  <main id="inicio">

    <!-- ============ 01 · HERO ============ -->
    <section class="relative bg-wave text-white overflow-hidden">
      <FlowLines tone="dark" />
      <div class="container-g2b relative z-10 grid items-center gap-12 pt-16 pb-28 lg:grid-cols-12 lg:gap-8 lg:pt-24 lg:pb-36">

        <div class="lg:col-span-7">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-water-300/80">
            Plataforma empresarial · Cobertura nacional
          </p>
          <!-- H1 tipográfico con clamp para punch editorial en todos los breakpoints -->
          <h1 class="mt-7 font-display font-extrabold leading-[0.93] tracking-tight" style="font-size: clamp(2.8rem, 9vw, 7.5rem)">
            Infraestructura<br>
            que <span class="text-water-400">transforma</span><br>
            México.
          </h1>
          <p class="mt-7 max-w-xl text-lg text-steel-100/90 leading-relaxed">
            Somos un grupo constructor integrado por cinco empresas especializadas, con la
            capacidad técnica, operativa y financiera para desarrollar proyectos
            <strong class="font-semibold text-white">llave en mano</strong> de alto impacto a nivel nacional.
          </p>
          <div class="mt-9 flex flex-col sm:flex-row gap-4">
            <a href="#contacto" class="inline-flex items-center justify-center gap-2 rounded-lg bg-water-500 px-7 py-3.5 font-semibold text-white hover:bg-water-400 transition-colors">
              Solicitar propuesta <Icon name="arrow" class="w-4 h-4" />
            </a>
            <a href="#empresas" class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/25 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition-colors">
              Conocer el grupo
            </a>
          </div>
        </div>

        <div class="lg:col-span-5">
          <!-- Ficha del grupo -->
          <div class="rounded-brand border border-white/15 bg-white/[0.04] backdrop-blur-sm">
            <div class="flex items-center justify-between border-b border-white/10 px-6 py-3">
              <span class="text-[11px] font-semibold uppercase tracking-[0.18em] text-steel-100/70">Ficha del grupo</span>
              <span class="sec-index text-xs text-water-400">G2B · 2026</span>
            </div>
            <dl class="divide-y divide-white/10">
              {readout.map((r) => (
                <div class="flex items-end justify-between gap-4 px-6 py-5">
                  <dt class="max-w-[10rem] text-sm text-steel-100/85">
                    {r.label}
                    <span class="mt-0.5 block text-[11px] text-steel-100/50">{r.sub}</span>
                  </dt>
                  <dd class="stat-mega text-4xl text-white sm:text-5xl">
                    <span class="counter" data-target={r.value} data-prefix={r.prefix} data-suffix={r.suffix}>{r.prefix}0{r.suffix}</span>
                  </dd>
                </div>
              ))}
            </dl>
          </div>
          <!-- Pilares de marca -->
          <div class="mt-4 grid grid-cols-3 gap-3">
            {brand.pillars.map((p) => (
              <div class="rounded-brand border border-white/10 bg-white/[0.03] px-4 py-3 text-center">
                <span class="block text-xs font-semibold uppercase tracking-[0.12em] text-water-200">{p}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <svg class="relative z-10 block w-full" viewBox="0 0 1440 70" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path class="water-draw" style="--len:1" pathLength="1" d="M0 40 C 180 10, 320 70, 520 40 S 900 10, 1080 40 1440 35 1440 35" stroke="var(--color-water-400)" stroke-width="2" opacity="0.55" />
        <path d="M0 50 C 180 22, 320 78, 520 50 S 900 22, 1080 50 1440 46 L1440 70 L0 70 Z" fill="rgba(56,182,224,0.08)" />
      </svg>
    </section>

    <!-- ============ 02 · NUESTRAS EMPRESAS ============ -->
    <section id="empresas" class="relative overflow-hidden py-20 lg:py-28">
      <FlowLines tone="light" />
      <div class="container-g2b relative z-10">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <div class="mb-4 h-[3px] w-10 rounded-full bg-water-500"></div>
            <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.6rem] lg:leading-[1.05]">Una plataforma, cinco empresas especializadas</h2>
          </div>
          <p class="max-w-sm text-steel-700">Cada compañía aporta su especialidad; juntas, cubren el ciclo completo de un proyecto de infraestructura.</p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {companies.map((c, i) => (
            <article
              class="group flex flex-col overflow-hidden rounded-brand border border-steel-100 bg-white transition-all hover:-translate-y-1 hover:shadow-xl"
            >
              <!-- Área de foto (Higgsfield) / placeholder con gradiente de marca -->
              <div class="relative h-44 overflow-hidden" style={`background: linear-gradient(140deg, ${c.color}28 0%, ${c.color}0a 100%); border-top: 3px solid ${c.color}`}>
                {c.img
                  ? <img src={c.img} alt={`${c.name} — obra`} class="h-full w-full object-cover" loading="lazy" />
                  : (
                    <>
                      <!-- número watermark en el área de foto -->
                      <span
                        class="pointer-events-none absolute -right-3 -bottom-4 select-none font-display font-extrabold leading-none"
                        style={`color:${c.color}; opacity:0.12; font-size:8rem`}
                        aria-hidden="true"
                      >{String(i + 1).padStart(2, "0")}</span>
                    </>
                  )
                }
                <!-- Logo / placeholder de logo -->
                <div class="absolute bottom-3 left-4">
                  {c.logo
                    ? <img src={c.logo} alt={`Logo ${c.name}`} class="h-8 w-auto" />
                    : (
                      <span class="inline-block rounded bg-white/90 px-2.5 py-1 text-xs font-bold tracking-wide shadow-sm" style={`color:${c.color}`}>
                        {c.name}
                      </span>
                    )
                  }
                </div>
              </div>

              <!-- Contenido -->
              <div class="relative flex flex-1 flex-col p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-steel-500">{c.specialty}</p>
                <p class="mt-2 text-sm leading-relaxed text-steel-700 flex-1">{c.desc}</p>
                <ul class="mt-4 space-y-1.5">
                  {c.services.slice(0, 3).map((s) => (
                    <li class="flex items-center gap-2 text-sm text-steel-700">
                      <Icon name="check" class="w-4 h-4 shrink-0 text-eco-500" />{s}
                    </li>
                  ))}
                </ul>
                {c.note && <p class="mt-3 text-xs text-steel-500">{c.note}</p>}
                {c.website && (
                  <a
                    href={c.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors hover:opacity-80"
                    style={`color:${c.color}`}
                  >
                    Ver sitio <Icon name="arrow" class="w-4 h-4" />
                  </a>
                )}
              </div>
            </article>
          ))}
          <!-- Tarjeta cierre del grupo -->
          <article class="relative flex flex-col justify-center overflow-hidden rounded-brand bg-navy-800 p-7 text-white">
            <Monogram tone="dark" class="text-[10rem] -right-6 -bottom-10" />
            <p class="relative font-display text-xl font-bold leading-snug">Un solo grupo,<br />toda la capacidad.</p>
            <p class="relative mt-3 text-sm text-steel-100/80">Proyectos llave en mano que combinan la fuerza de las cinco empresas en una sola gestión.</p>
            <a href="#contacto" class="relative mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-water-400 hover:text-water-300 transition-colors">
              Hablemos de tu proyecto <Icon name="arrow" class="w-4 h-4" />
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ 03 · MODELO INTEGRAL ============ -->
    <section id="modelo" class="relative bg-wave py-20 text-white lg:py-28 overflow-hidden">
      <FlowLines tone="dark" />
      <Monogram tone="dark" class="text-[24rem] -right-16 -bottom-28 hidden lg:block" />
      <div class="container-g2b relative z-10">
        <div class="max-w-2xl">
          <div class="mb-4 h-[3px] w-10 rounded-full bg-water-400"></div>
          <h2 class="font-display text-3xl font-bold lg:text-[2.4rem]">Proyectos llave en mano, de principio a fin</h2>
          <p class="mt-4 text-lg text-steel-100/90">Un modelo que combina planeación, ingeniería, suministro, fabricación, construcción, logística y operación — con ejecución simultánea de múltiples frentes de obra.</p>
        </div>

        <ol class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-6 lg:gap-5">
          {integralModel.map((m, i) => (
            <li class="r-in relative pt-8" style={`--d:${i * 120 + 150}ms`}>
              <!-- número grande editorial — única numeración -->
              <span
                class="pointer-events-none absolute left-0 top-0 select-none font-display font-extrabold leading-none stat-mega text-water-400"
                style="font-size:4.5rem; opacity:0.15"
                aria-hidden="true"
              >{m.n}</span>
              <h3 class="relative font-display text-[0.95rem] font-bold leading-tight">{m.title}</h3>
              <p class="relative mt-2 text-sm leading-relaxed text-steel-100/80">{m.desc}</p>
            </li>
          ))}
        </ol>
        <p class="mt-14 font-display text-xl font-semibold text-water-200">{brand.taglines.team}</p>
      </div>
    </section>

    <!-- ============ 04 · ESPECIALIDAD + DIFERENCIADORES ============ -->
    <section id="especialidad" class="relative overflow-hidden py-20 lg:py-28">
      <FlowLines tone="light" />
      <div class="container-g2b relative z-10">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
          <div class="lg:col-span-5">
            <div class="mb-4 h-[3px] w-10 rounded-full bg-water-500"></div>
            <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">Toda la capacidad para construir el futuro de México</h2>
            <div class="mt-8 grid gap-5 sm:grid-cols-2">
              {differentiators.map((d) => (
                <div class="r-in border-t-2 border-water-500 bg-white p-5 shadow-sm">
                  <p class="font-display text-base font-bold text-navy-900">{d.t}</p>
                  <p class="mt-1 text-sm leading-relaxed text-steel-700">{d.d}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:col-span-7">
            <p class="text-sm font-semibold uppercase tracking-wider text-steel-600">Áreas de especialidad</p>
            <div class="mt-5 grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4">
              {specialties.map((s) => (
                <div class="flex flex-col items-center gap-3 rounded-brand border border-steel-100 bg-paper p-6 text-center transition-colors hover:border-water-500/40 hover:bg-white">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-navy-800/5 text-navy-800">
                    <Icon name={s.icon} class="w-6 h-6" />
                  </div>
                  <span class="text-sm font-semibold text-navy-900">{s.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 05 · CAPACIDAD OPERATIVA — sección oscura para romper ritmo ============ -->
    <section id="capacidad" class="relative overflow-hidden bg-navy-950 py-20 text-white lg:py-28">
      <FlowLines tone="dark" />
      <div class="container-g2b relative z-10">
        <div class="grid gap-10 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <div class="mb-4 h-[3px] w-10 rounded-full bg-water-400"></div>
            <h2 class="font-display text-3xl font-bold lg:text-[2.4rem] lg:leading-[1.05]">Infraestructura propia, lista para cualquier reto</h2>
            <p class="mt-4 text-steel-100/75">Maquinaria, plantas y transporte propios que permiten al grupo ejecutar múltiples proyectos de gran escala con eficiencia, seguridad y calidad.</p>
            <div class="mt-8 border-t-2 border-water-400 pt-5">
              <p class="text-xs uppercase tracking-widest text-water-400/70">Total de equipos</p>
              <p class="stat-mega mt-1 leading-none" style="font-size: clamp(3.5rem, 8vw, 6.5rem)">
                <span class="text-white">{totalCapacity}</span><span class="text-water-400">+</span>
              </p>
              <p class="mt-2 text-sm text-steel-100/50">Equipos, plantas y unidades propias</p>
            </div>
          </div>
          <div class="grid gap-8 sm:grid-cols-3 lg:col-span-8">
            {Object.entries(capacity).map(([group, items]) => (
              <div>
                <h3 class="border-b border-white/15 pb-3 text-xs font-bold uppercase tracking-wider text-water-400">{group}</h3>
                <ul class="mt-2 divide-y divide-white/10">
                  {items.map((it) => (
                    <li class="flex items-center justify-between gap-3 py-2.5">
                      <span class="text-sm text-steel-100/75">{it.item}</span>
                      <span class="stat-mega text-lg text-water-400">{it.qty}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 06 · TRAYECTORIA ============ -->
    <section id="experiencia" class="relative overflow-hidden bg-paper py-20 lg:py-28">
      <FlowLines tone="light" />
      <div class="container-g2b relative z-10">
        <div class="mb-4 h-[3px] w-10 rounded-full bg-water-500"></div>
        <div class="mt-6 grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
          <div>
            <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">Casi mil millones de pesos en obra ejecutada</h2>
            <div class="mt-8 border-t-2 border-navy-800 pt-5">
              <p class="text-xs uppercase tracking-widest text-steel-600">Monto total ejecutado (MXN)</p>
              <!-- Contador protagonista — tamaño editorial -->
              <p class="stat-mega mt-1 leading-none text-navy-800" style="font-size: clamp(3.5rem, 10vw, 8rem)">
                <span class="counter" data-target="943" data-prefix="$" data-suffix="M">$0M</span>
              </p>
            </div>
            <div class="mt-8 space-y-5">
              {experience.bySector.map((sec) => (
                <div>
                  <div class="mb-2 flex justify-between text-sm font-medium text-navy-900">
                    <span>{sec.label}</span><span class="stat-mega">{fmtM(sec.amount)}</span>
                  </div>
                  <div class="h-3 overflow-hidden rounded-full bg-steel-100">
                    <div class="h-3 rounded-full bg-water-500" style={`width:${(sec.amount / (experience.bySector[0].amount + experience.bySector[1].amount) * 100).toFixed(1)}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-brand border border-steel-100 bg-white p-7 lg:p-8">
            <h3 class="font-display text-lg font-bold text-navy-900">Distribución por tipo de obra</h3>
            <ul class="mt-6 space-y-5">
              {experience.byType.map((t) => (
                <li>
                  <div class="mb-2 flex items-baseline justify-between gap-3">
                    <span class="text-sm font-medium text-navy-900">{t.label}</span>
                    <span class="stat-mega shrink-0 text-sm text-water-600">{fmtM(t.amount)}</span>
                  </div>
                  <div class="h-3 overflow-hidden rounded-full bg-steel-100">
                    <div class="h-3 rounded-full bg-navy-700" style={`width:${(t.amount / maxType * 100).toFixed(1)}%`}></div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="mt-14">
          <h3 class="font-display text-xl font-bold text-navy-900">Proyectos destacados</h3>
          <div class="mt-5 grid gap-6 md:grid-cols-3">
            {[1, 2, 3].map(() => (
              <div class="media-slot duotone h-52 rounded-brand text-white/75">
                Caso de éxito — pendiente del cliente<br />(empresa · cliente · ubicación · monto · foto)
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 07 · PARA QUIÉN TRABAJAMOS — layout editorial, no tarjetas genéricas ============ -->
    <section id="audiencias" class="py-20 lg:py-28">
      <div class="container-g2b">
        <div class="mb-4 h-[3px] w-10 rounded-full bg-water-500"></div>
        <div class="mt-6 grid gap-10 lg:grid-cols-[1fr_1.5fr] lg:items-start">
          <h2 class="font-display text-3xl font-bold text-navy-900 lg:text-[2.4rem] lg:leading-[1.05]">
            Aliados estratégicos para gobiernos, inversionistas y desarrolladores
          </h2>
          <div class="divide-y divide-steel-100">
            {audiencesGroup.map((a, i) => (
              <div class="r-in grid grid-cols-[5rem_1fr] items-start gap-6 py-8 first:pt-0 last:pb-0" style={`--d:${i * 120}ms`}>
                <div class="flex flex-col items-center gap-3 pt-1">
                  <span class="sec-index select-none font-extrabold leading-none text-navy-800/[0.09]" style="font-size:2.8rem">{String(i + 1).padStart(2, "0")}</span>
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-navy-800/5 text-navy-800">
                    <Icon name={a.icon} class="w-5 h-5" />
                  </div>
                </div>
                <div>
                  <h3 class="font-display text-xl font-bold text-navy-900">{a.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-steel-700">{a.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 08 · CONTACTO ============ -->
    <section id="contacto" class="relative overflow-hidden bg-wave py-20 text-white lg:py-28">
      <FlowLines tone="dark" />
      <Monogram tone="dark" class="hidden -left-16 -bottom-32 text-[24rem] lg:block" />
      <div class="container-g2b relative z-10 grid gap-12 lg:grid-cols-2">
        <div>
          <div class="mb-4 h-[3px] w-10 rounded-full bg-water-400"></div>
          <h2 class="font-display text-3xl font-bold lg:text-[2.4rem]">Construyamos juntos el siguiente proyecto</h2>
          <p class="mt-4 max-w-md text-lg text-steel-100/90">{brand.taglines.team}</p>
          <ul class="mt-8 space-y-4 text-steel-100/85">
            <li class="flex items-center gap-3"><Icon name="phone" class="w-5 h-5 shrink-0 text-water-400" /><span>{brand.contact.phone || "Teléfono — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="mail" class="w-5 h-5 shrink-0 text-water-400" /><span>{brand.contact.email || "Correo — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="whatsapp" class="w-5 h-5 shrink-0 text-water-400" /><span>{brand.contact.whatsapp || "WhatsApp — pendiente del cliente"}</span></li>
            <li class="flex items-center gap-3"><Icon name="pin" class="w-5 h-5 shrink-0 text-water-400" /><span>{brand.contact.address || "Dirección — pendiente del cliente"}</span></li>
          </ul>
        </div>

        <form
          class="rounded-brand bg-white p-7 text-navy-900 shadow-2xl lg:p-8"
          onsubmit="event.preventDefault(); this.querySelector('#form-msg').classList.remove('hidden');"
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium">Nombre</span>
              <input type="text" required autocomplete="name" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Empresa / Dependencia</span>
              <input type="text" autocomplete="organization" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Correo</span>
              <input type="email" required autocomplete="email" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Teléfono</span>
              <input type="tel" autocomplete="tel" class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200" />
            </label>
          </div>
          <label class="mt-4 block">
            <span class="text-sm font-medium">Empresa del grupo de interés</span>
            <select class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200">
              <option>Grupo G2B (proyecto integral)</option>
              {companies.map((c) => <option>{c.name} — {c.specialty}</option>)}
            </select>
          </label>
          <label class="mt-4 block">
            <span class="text-sm font-medium">Mensaje</span>
            <textarea rows={3} class="mt-1 w-full rounded-lg border border-steel-300 px-3.5 py-2.5 text-sm outline-none focus:border-water-500 focus:ring-2 focus:ring-water-200"></textarea>
          </label>
          <button type="submit" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-water-600 px-6 py-3.5 font-semibold text-white hover:bg-water-500 transition-colors">
            Enviar solicitud <Icon name="arrow" class="w-4 h-4" />
          </button>
          <p id="form-msg" role="status" aria-live="polite" class="mt-3 hidden text-center text-sm font-medium text-eco-600">¡Gracias! (Demo — falta conectar el envío del formulario.)</p>
        </form>
      </div>
    </section>

  </main>

  <Footer />

  <script>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fmt = (n: number) => n.toLocaleString("es-MX");

    const animate = (el: HTMLElement) => {
      const target = Number(el.dataset.target ?? "0");
      const prefix = el.dataset.prefix ?? "";
      const suffix = el.dataset.suffix ?? "";
      if (reduceMotion) { el.textContent = prefix + fmt(target) + suffix; return; }
      const dur = 1500;
      const start = performance.now();
      const step = (t: number) => {
        const p = Math.min((t - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + fmt(Math.floor(eased * target)) + suffix;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = prefix + fmt(target) + suffix;
      };
      requestAnimationFrame(step);
    };

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const t = e.target as HTMLElement;
        if (t.classList.contains("counter")) animate(t);
        t.classList.add("is-in");
        io.unobserve(t);
      });
    }, { threshold: 0.25 });

    document.querySelectorAll(".counter, .r-in, .water-draw").forEach((el) => io.observe(el));
  </script>
</Base>
